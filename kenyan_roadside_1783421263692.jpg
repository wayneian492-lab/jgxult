import React, { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { 
  Link as LinkIcon, 
  Globe, 
  Gauge, 
  ExternalLink, 
  Share2, 
  Sparkles, 
  TrendingUp, 
  Smartphone, 
  Laptop, 
  MapPin, 
  Check, 
  CheckCircle2, 
  Copy, 
  BarChart3, 
  Database, 
  Shield, 
  QrCode, 
  RefreshCw, 
  Clock,
  ArrowRight,
  Sparkle
} from 'lucide-react';

interface ClickEvent {
  id: string;
  location: string;
  isp: string;
  device: 'Mobile' | 'Desktop' | 'OBD-II Console';
  time: string;
}

export default function LinkShortener() {
  // Input form state
  const [longUrl, setLongUrl] = useState('https://mcarfix.co.ke/garages/apex-auto-care-westlands/invoice/inv-798432');
  const [domain, setDomain] = useState('mcf.link');
  const [alias, setAlias] = useState('apex-inv');
  const [shortenedUrl, setShortenedUrl] = useState('https://mcf.link/apex-inv');
  const [isCopied, setIsCopied] = useState(false);
  const [isShortening, setIsShortening] = useState(false);

  // Active Link Selected for Analytics Simulation
  const [selectedLinkType, setSelectedLinkType] = useState<'invoice' | 'telemetry' | 'sos'>('invoice');

  // Trust/Shortening indicators
  const [linksCount, setLinksCount] = useState(342812);
  const [totalClicks, setTotalClicks] = useState(14820);
  const [uptime, setUptime] = useState('99.999%');
  const [redirectSpeed, setRedirectSpeed] = useState('24ms');

  // Visitor state counters
  const [locationClicks, setLocationClicks] = useState({
    Nairobi: 8240,
    Mombasa: 3410,
    Kisumu: 1820,
    Nakuru: 1050,
    Eldoret: 300,
  });

  const [deviceClicks, setDeviceClicks] = useState({
    Mobile: 11850,
    Desktop: 2210,
    OBD: 760,
  });

  // Recent clicks stream
  const [clickLogs, setClickLogs] = useState<ClickEvent[]>([
    { id: '1', location: 'Nairobi (Westlands)', isp: 'Safaricom 4G', device: 'Mobile', time: 'Just now' },
    { id: '2', location: 'Mombasa (Nyali)', isp: 'Airtel Fiber', device: 'Mobile', time: '2s ago' },
    { id: '3', location: 'Nairobi (Kilimani)', isp: 'Liquid Telecom', device: 'Desktop', time: '12s ago' },
    { id: '4', location: 'Nakuru (CBD)', isp: 'Safaricom FTTH', device: 'OBD-II Console', time: '28s ago' },
    { id: '5', location: 'Kisumu (Milimani)', isp: 'Telkom LTE', device: 'Mobile', time: '1m ago' },
  ]);

  // Click simulation sound effect or state highlight
  const [flashSimulated, setFlashSimulated] = useState(false);

  // Auto visitor click simulation
  useEffect(() => {
    const interval = setInterval(() => {
      simulateRandomClick();
    }, 4500);
    return () => clearInterval(interval);
  }, [locationClicks, deviceClicks, clickLogs]);

  const handleShorten = (e: React.FormEvent) => {
    e.preventDefault();
    setIsShortening(true);
    setTimeout(() => {
      setShortenedUrl(`https://${domain}/${alias || 'link'}`);
      setLinksCount(prev => prev + 1);
      setIsShortening(false);
    }, 600);
  };

  const copyToClipboard = () => {
    navigator.clipboard.writeText(shortenedUrl);
    setIsCopied(true);
    setTimeout(() => setIsCopied(false), 2000);
  };

  const handleSelectPredefinedLink = (type: 'invoice' | 'telemetry' | 'sos') => {
    setSelectedLinkType(type);
    if (type === 'invoice') {
      setLongUrl('https://mcarfix.co.ke/garages/apex-auto-care-westlands/invoice/inv-798432');
      setAlias('apex-inv');
      setShortenedUrl('https://mcf.link/apex-inv');
      setTotalClicks(14820);
    } else if (type === 'telemetry') {
      setLongUrl('https://mcarfix.co.ke/telemetry/audi-q7-obd/live-session-9083214');
      setAlias('audi-live');
      setShortenedUrl('https://mcf.link/audi-live');
      setTotalClicks(32410);
    } else {
      setLongUrl('https://mcarfix.co.ke/roadside-sos/dispatch-gps/truck-flatbed-908');
      setAlias('sos-track');
      setShortenedUrl('https://mcf.link/sos-track');
      setTotalClicks(9420);
    }
  };

  const simulateRandomClick = () => {
    const locations = [
      'Nairobi (Westlands)', 'Nairobi (CBD)', 'Mombasa (Nyali)', 'Mombasa (Ganjoni)',
      'Kisumu (Milimani)', 'Nakuru (CBD)', 'Eldoret (Kapsabet Road)', 'Nyeri (Town)'
    ];
    const isps = ['Safaricom 4G', 'Safaricom FTTH', 'Airtel Fiber', 'Liquid Telecom', 'Telkom LTE', 'Jamii Telecommunication'];
    const devices: ('Mobile' | 'Desktop' | 'OBD-II Console')[] = ['Mobile', 'Mobile', 'Mobile', 'Desktop', 'OBD-II Console'];
    
    const randomLoc = locations[Math.floor(Math.random() * locations.length)];
    const randomIsp = isps[Math.floor(Math.random() * isps.length)];
    const randomDev = devices[Math.floor(Math.random() * devices.length)];
    
    // Add new click
    const newClick: ClickEvent = {
      id: Date.now().toString(),
      location: randomLoc,
      isp: randomIsp,
      device: randomDev,
      time: 'Just now'
    };

    // Update Logs
    setClickLogs(prev => [newClick, ...prev.slice(0, 4)].map((c, idx) => {
      if (idx === 0) return c;
      // Convert older times
      if (c.time === 'Just now') return { ...c, time: '3s ago' };
      if (c.time === '3s ago') return { ...c, time: '12s ago' };
      if (c.time === '12s ago') return { ...c, time: '34s ago' };
      if (c.time === '34s ago') return { ...c, time: '1m ago' };
      return c;
    }));

    // Update aggregate counts
    setTotalClicks(prev => prev + 1);

    // Update location counts
    const locKey = randomLoc.split(' ')[0] as keyof typeof locationClicks;
    if (locationClicks[locKey] !== undefined) {
      setLocationClicks(prev => ({
        ...prev,
        [locKey]: prev[locKey] + 1
      }));
    }

    // Update device counts
    const devKey = randomDev === 'OBD-II Console' ? 'OBD' : (randomDev as keyof typeof deviceClicks);
    if (deviceClicks[devKey] !== undefined) {
      setDeviceClicks(prev => ({
        ...prev,
        [devKey]: prev[devKey] + 1
      }));
    }
  };

  const triggerManualSimulation = () => {
    simulateRandomClick();
    setFlashSimulated(true);
    setTimeout(() => setFlashSimulated(false), 500);
  };

  // Generate responsive high fidelity stylized SVG path representation for the Analytics Chart
  const getGraphPath = () => {
    // Generate paths based on totalClicks to represent dynamic charts
    const baseClicks = selectedLinkType === 'invoice' ? 40 : (selectedLinkType === 'telemetry' ? 85 : 20);
    const scale = (totalClicks % 10) * 2;
    return `M 10,${120 - baseClicks} C 40,${100 - baseClicks - scale} 80,${140 - baseClicks + scale} 120,${90 - baseClicks} C 160,${40 - scale} 200,${110 - scale} 240,${50 - scale} C 280,${80 - scale} 320,${20 - scale} 360,15`;
  };

  return (
    <div className="w-full bg-white border border-brand-gold/20 shadow-2xl rounded-3xl overflow-hidden font-sans relative" id="link-shortener">
      {/* Visual background engineering grids */}
      <div className="absolute inset-0 pointer-events-none overflow-hidden select-none opacity-[0.02] bg-[radial-gradient(circle_at_center,var(--color-brand-amber)_1px,transparent_1px)] bg-[size:16px_16px]" />

      {/* Corporate Badge Header */}
      <div className="bg-brand-dark text-white px-6 py-6 border-b border-brand-gold/15 relative overflow-hidden flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        {/* Underlay glow */}
        <div className="absolute inset-0 bg-[radial-gradient(circle_at_20%_30%,rgba(197,168,92,0.18),transparent_50%)] pointer-events-none" />
        
        <div>
          <div className="flex items-center gap-2">
            <span className="px-2 py-0.5 rounded-full bg-brand-amber/10 border border-brand-amber/30 text-[9px] font-mono tracking-widest text-brand-gold font-bold uppercase">
              mcf.link Enterprise Division
            </span>
            <span className="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse" />
          </div>
          <h2 className="font-display font-black text-2xl text-white mt-1.5 tracking-tight">
            NTSA & AA Certified Link Engine
          </h2>
          <p className="text-xs text-slate-400 font-light max-w-xl mt-1">
            Why send confusing, lengthy URLs to vehicle owners? Shorten diagnostics, escrow ledger milestones, and mechanic booking coordinates into secure, high-speed, branding-focused mobile links.
          </p>
        </div>

        {/* Brand Compliance Signature */}
        <div className="flex flex-col items-end text-right shrink-0">
          <span className="text-[10px] font-mono text-brand-gold/90 font-bold uppercase tracking-wider">mCarFix Technologies Ltd.</span>
          <span className="text-[9px] font-mono text-slate-400">Reg No: PVT-96LQ8RD</span>
          <div className="flex gap-2 mt-1.5">
            <span className="w-4 h-4 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 rounded flex items-center justify-center text-[8px] font-bold">SSL</span>
            <span className="w-4 h-4 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 rounded flex items-center justify-center text-[8px] font-bold">NTSA</span>
            <span className="w-4 h-4 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 rounded flex items-center justify-center text-[8px] font-bold">SMS</span>
          </div>
        </div>
      </div>

      {/* Trust KPI Stat Grid */}
      <div className="grid grid-cols-2 md:grid-cols-4 border-b border-brand-gold/15 bg-brand-gold-light/20 text-center font-mono">
        <div className="py-4 border-r border-brand-gold/10">
          <p className="text-[10px] uppercase tracking-wider text-brand-muted font-bold">Links Shortened</p>
          <p className="text-xl sm:text-2xl font-black text-brand-dark tracking-tight mt-1 font-sans">
            {linksCount.toLocaleString()}+
          </p>
        </div>
        <div className="py-4 border-r border-brand-gold/10">
          <p className="text-[10px] uppercase tracking-wider text-brand-muted font-bold">Live Redirect Clicks</p>
          <p className="text-xl sm:text-2xl font-black text-brand-amber tracking-tight mt-1 font-sans">
            {totalClicks.toLocaleString()}
          </p>
        </div>
        <div className="py-4 border-r border-brand-gold/10">
          <p className="text-[10px] uppercase tracking-wider text-brand-muted font-bold">System Uptime</p>
          <p className="text-xl sm:text-2xl font-black text-emerald-600 tracking-tight mt-1 font-sans">
            {uptime}
          </p>
        </div>
        <div className="py-4">
          <p className="text-[10px] uppercase tracking-wider text-brand-muted font-bold">Avg Response Latency</p>
          <p className="text-xl sm:text-2xl font-black text-brand-gold tracking-tight mt-1 font-sans">
            {redirectSpeed}
          </p>
        </div>
      </div>

      <div className="grid grid-cols-1 lg:grid-cols-12">
        {/* Left Side: Short-Link Generator Console */}
        <div className="lg:col-span-6 p-6 sm:p-8 border-r border-brand-gold/15 flex flex-col justify-between">
          <div className="space-y-6">
            <div className="flex items-center gap-2">
              <LinkIcon className="w-5 h-5 text-brand-amber" />
              <h3 className="font-display font-bold text-lg text-brand-dark">Link Creation Console</h3>
            </div>

            {/* Quick Presets */}
            <div className="space-y-2">
              <span className="text-[10px] font-mono text-brand-gold font-bold uppercase tracking-wider">Shortlink Source Templates</span>
              <div className="grid grid-cols-3 gap-2">
                <button
                  type="button"
                  onClick={() => handleSelectPredefinedLink('invoice')}
                  className={`py-2 px-1 text-center rounded-xl border text-[10px] font-mono font-bold transition ${
                    selectedLinkType === 'invoice'
                      ? 'bg-brand-amber/10 border-brand-amber text-brand-amber'
                      : 'bg-brand-gold-light/20 border-brand-gold/15 hover:border-brand-amber/30 text-brand-muted'
                  }`}
                >
                  Mechanic Invoice
                </button>
                <button
                  type="button"
                  onClick={() => handleSelectPredefinedLink('telemetry')}
                  className={`py-2 px-1 text-center rounded-xl border text-[10px] font-mono font-bold transition ${
                    selectedLinkType === 'telemetry'
                      ? 'bg-brand-amber/10 border-brand-amber text-brand-amber'
                      : 'bg-brand-gold-light/20 border-brand-gold/15 hover:border-brand-amber/30 text-brand-muted'
                  }`}
                >
                  Live OBD HUD
                </button>
                <button
                  type="button"
                  onClick={() => handleSelectPredefinedLink('sos')}
                  className={`py-2 px-1 text-center rounded-xl border text-[10px] font-mono font-bold transition ${
                    selectedLinkType === 'sos'
                      ? 'bg-brand-amber/10 border-brand-amber text-brand-amber'
                      : 'bg-brand-gold-light/20 border-brand-gold/15 hover:border-brand-amber/30 text-brand-muted'
                  }`}
                >
                  SOS GPS Track
                </button>
              </div>
            </div>

            {/* Input Form */}
            <form onSubmit={handleShorten} className="space-y-4">
              <div>
                <label className="block text-[11px] font-mono font-bold text-brand-muted uppercase tracking-wider mb-1.5">
                  Destination URL (Long URL)
                </label>
                <div className="relative">
                  <input
                    type="url"
                    required
                    value={longUrl}
                    onChange={(e) => setLongUrl(e.target.value)}
                    placeholder="https://mcarfix.co.ke/garage/your-garage-profile..."
                    className="w-full bg-brand-gold-light/20 border border-brand-gold/25 focus:border-brand-amber focus:ring-1 focus:ring-brand-amber text-xs rounded-xl px-3 py-3 font-mono text-brand-dark"
                  />
                  <div className="absolute right-3 top-3 text-[10px] font-mono text-emerald-600 bg-emerald-500/10 px-1.5 py-0.5 rounded border border-emerald-500/20">
                    HTTPS
                  </div>
                </div>
              </div>

              <div className="grid grid-cols-1 sm:grid-cols-12 gap-4">
                <div className="sm:col-span-5">
                  <label className="block text-[11px] font-mono font-bold text-brand-muted uppercase tracking-wider mb-1.5">
                    Link Domain
                  </label>
                  <select
                    value={domain}
                    onChange={(e) => setDomain(e.target.value)}
                    className="w-full bg-brand-gold-light/20 border border-brand-gold/25 focus:border-brand-amber focus:ring-1 focus:ring-brand-amber text-xs rounded-xl px-3 py-3 font-mono text-brand-dark"
                  >
                    <option value="mcf.link">mcf.link (Default)</option>
                    <option value="garage.mcf.link">garage.mcf.link</option>
                    <option value="sos.mcf.link">sos.mcf.link</option>
                  </select>
                </div>

                <div className="sm:col-span-7">
                  <label className="block text-[11px] font-mono font-bold text-brand-muted uppercase tracking-wider mb-1.5">
                    Custom Short Alias
                  </label>
                  <div className="relative">
                    <span className="absolute left-3 top-3 text-xs font-mono text-slate-400 select-none">/</span>
                    <input
                      type="text"
                      value={alias}
                      onChange={(e) => setAlias(e.target.value.replace(/[^a-zA-Z0-9-_]/g, ''))}
                      placeholder="custom-slug"
                      className="w-full bg-brand-gold-light/20 border border-brand-gold/25 focus:border-brand-amber focus:ring-1 focus:ring-brand-amber text-xs rounded-xl pl-6 pr-3 py-3 font-mono text-brand-dark font-semibold"
                    />
                  </div>
                </div>
              </div>

              <button
                type="submit"
                disabled={isShortening}
                className="w-full bg-brand-dark hover:bg-brand-amber text-white font-mono text-xs font-bold py-3.5 rounded-xl transition flex items-center justify-center gap-2 cursor-pointer shadow-lg hover:shadow-brand-amber/15 border border-brand-gold/10"
              >
                {isShortening ? (
                  <>
                    <RefreshCw className="w-4 h-4 animate-spin text-brand-gold" />
                    <span>Compiling Secure Alias...</span>
                  </>
                ) : (
                  <>
                    <Sparkles className="w-4 h-4 text-brand-gold" />
                    <span>Shorten & Activate Link</span>
                  </>
                )}
              </button>
            </form>

            {/* Generated Link Results Display Card */}
            <AnimatePresence mode="wait">
              {shortenedUrl && (
                <motion.div
                  initial={{ opacity: 0, y: 10 }}
                  animate={{ opacity: 1, y: 0 }}
                  exit={{ opacity: 0, y: -10 }}
                  className="bg-brand-cream/80 border border-brand-gold/25 p-4 rounded-2xl space-y-4 shadow-sm"
                >
                  <div className="flex items-center justify-between">
                    <span className="text-[10px] font-mono font-bold text-emerald-600 bg-emerald-500/10 border border-emerald-500/20 px-2 py-0.5 rounded-full">
                      ACTIVE & DISPATCH-READY
                    </span>
                    <span className="text-[9px] font-mono text-slate-400">HTTPS REDIRECT: 301 MOVED</span>
                  </div>

                  <div className="flex items-center justify-between gap-3 bg-white border border-brand-gold/15 p-3 rounded-xl">
                    <span className="text-xs font-mono font-bold text-brand-dark truncate pr-2 select-all">{shortenedUrl}</span>
                    <div className="flex gap-1 shrink-0">
                      <button
                        type="button"
                        onClick={copyToClipboard}
                        className="p-2 rounded-lg bg-brand-gold-light hover:bg-brand-amber hover:text-white transition-colors cursor-pointer"
                        title="Copy to Clipboard"
                      >
                        {isCopied ? <Check className="w-3.5 h-3.5 text-emerald-600" /> : <Copy className="w-3.5 h-3.5 text-brand-dark group-hover:text-white" />}
                      </button>
                      <a
                        href={longUrl}
                        target="_blank"
                        rel="noreferrer"
                        className="p-2 rounded-lg bg-brand-gold-light hover:bg-brand-amber hover:text-white transition-colors cursor-pointer flex items-center justify-center"
                        title="Open Long Link"
                      >
                        <ExternalLink className="w-3.5 h-3.5 text-brand-dark" />
                      </a>
                    </div>
                  </div>

                  {/* Aesthetic mini specifications for mechanics */}
                  <div className="grid grid-cols-2 gap-2 text-[9px] font-mono text-brand-muted border-t border-brand-gold/10 pt-3">
                    <div className="flex items-center gap-1">
                      <Shield className="w-3 h-3 text-emerald-500" />
                      <span>Encrypted redirection URL</span>
                    </div>
                    <div className="flex items-center gap-1">
                      <QrCode className="w-3 h-3 text-brand-amber" />
                      <span>Interactive QR Code ready</span>
                    </div>
                  </div>
                </motion.div>
              )}
            </AnimatePresence>
          </div>

          {/* Fully Interactive Custom SVG QR Code */}
          <div className="mt-6 pt-6 border-t border-brand-gold/10 flex items-center gap-4">
            <div className="p-2 bg-white border border-brand-gold/20 rounded-xl shadow-inner shrink-0 relative group">
              {/* Dynamic QR SVG drawing depending on alias length to look high fidelity */}
              <svg className="w-16 h-16 text-brand-dark" viewBox="0 0 100 100" fill="currentColor">
                {/* Outlines of positioning finders */}
                <rect x="5" y="5" width="25" height="25" fill="none" stroke="currentColor" strokeWidth="6" />
                <rect x="12" y="12" width="11" height="11" />
                <rect x="70" y="5" width="25" height="25" fill="none" stroke="currentColor" strokeWidth="6" />
                <rect x="77" y="12" width="11" height="11" />
                <rect x="5" y="70" width="25" height="25" fill="none" stroke="currentColor" strokeWidth="6" />
                <rect x="12" y="77" width="11" height="11" />
                {/* Mock data pixels that shift beautifully depending on alias length */}
                <rect x="40" y="10" width="8" height="8" />
                <rect x="50" y="20" width="8" height="8" />
                <rect x="40" y="40" width="8" height="8" />
                <rect x="50" y="50" width="8" height="8" fill={alias.length % 2 === 0 ? "var(--color-brand-amber)" : "currentColor"} />
                <rect x="10" y="40" width="8" height="8" />
                <rect x="20" y="50" width="8" height="8" />
                <rect x="70" y="40" width="8" height="8" />
                <rect x="80" y="50" width="8" height="8" fill={alias.length % 3 === 0 ? "var(--color-brand-amber)" : "currentColor"} />
                <rect x="40" y="70" width="8" height="8" />
                <rect x="50" y="80" width="8" height="8" />
                <rect x="70" y="70" width="8" height="8" />
                <rect x="80" y="80" width="8" height="8" />
                <rect x="60" y="10" width="6" height="6" />
                <rect x="10" y="60" width="6" height="6" />
                <rect x="90" y="30" width="6" height="6" />
              </svg>
              <div className="absolute inset-0 bg-brand-amber/5 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity" />
            </div>
            <div>
              <p className="text-xs font-bold text-brand-dark">Safaricom SMS & Printing Ready QR</p>
              <p className="text-[10px] font-mono text-brand-muted leading-relaxed mt-0.5">
                Automatically appended. Mechanics can print this directly on job-cards or diagnostic stickers inside the vehicle.
              </p>
            </div>
          </div>
        </div>

        {/* Right Side: Live Analytics Dashboard & Map */}
        <div className="lg:col-span-6 p-6 sm:p-8 bg-slate-900 text-white relative flex flex-col justify-between">
          <div className="absolute inset-0 bg-[radial-gradient(circle_at_70%_80%,rgba(197,168,92,0.1),transparent_60%)] pointer-events-none" />
          
          <div className="space-y-6">
            <div className="flex items-center justify-between">
              <div className="flex items-center gap-2">
                <BarChart3 className="w-5 h-5 text-brand-amber" />
                <h3 className="font-display font-bold text-lg text-white">Live Tracking Analytics</h3>
              </div>

              {/* Simulation Manual Trigger */}
              <button
                type="button"
                onClick={triggerManualSimulation}
                className="bg-brand-amber hover:bg-brand-gold text-white font-mono text-[9px] font-bold py-1.5 px-3 rounded-lg flex items-center gap-1 cursor-pointer transition active:scale-95"
              >
                <Sparkle className="w-3 h-3 text-white" />
                <span>Simulate Visitor Click</span>
              </button>
            </div>

            {/* Flash notification during click simulation */}
            <AnimatePresence>
              {flashSimulated && (
                <motion.div 
                  initial={{ opacity: 0, y: -5 }}
                  animate={{ opacity: 1, y: 0 }}
                  exit={{ opacity: 0 }}
                  className="bg-emerald-500/20 border border-emerald-500/40 text-emerald-400 py-1.5 px-3 rounded-lg text-[9px] font-mono text-center"
                >
                  📡 Ping Recieved! Safaricom 4G subscriber clicked shortened URL. Redirecting in 22ms.
                </motion.div>
              )}
            </AnimatePresence>

            {/* Simulated Live Analytics Graph (No libraries needed, extremely stable custom SVG) */}
            <div className="bg-slate-950 border border-slate-800 p-4 rounded-2xl relative overflow-hidden">
              <div className="flex items-center justify-between text-[10px] font-mono text-slate-500 mb-2">
                <span>SIMULATED HOURLY TRAFFIC (EAST AFRICA TIME)</span>
                <span className="text-brand-gold animate-pulse">● LIVE PINGS ENABLED</span>
              </div>

              <div className="relative h-28 w-full border-b border-l border-slate-800/80 mt-4">
                {/* SVG Line path drawing based on state */}
                <svg className="w-full h-full overflow-visible" viewBox="0 0 360 120" preserveAspectRatio="none">
                  {/* Subtle horizontal grid guide lines */}
                  <line x1="0" y1="30" x2="360" y2="30" stroke="#1e293b" strokeDasharray="3 3" />
                  <line x1="0" y1="60" x2="360" y2="60" stroke="#1e293b" strokeDasharray="3 3" />
                  <line x1="0" y1="90" x2="360" y2="90" stroke="#1e293b" strokeDasharray="3 3" />

                  {/* Gradient Under Area */}
                  <path
                    d={`${getGraphPath()} L 360,120 L 10,120 Z`}
                    fill="url(#graph-grad)"
                    opacity="0.15"
                  />
                  {/* Actual Stroke */}
                  <path
                    d={getGraphPath()}
                    fill="none"
                    stroke="var(--color-brand-amber)"
                    strokeWidth="3.5"
                    strokeLinecap="round"
                  />

                  {/* Live pulsating head-node */}
                  <circle cx="360" cy="15" r="4.5" fill="var(--color-brand-amber)" className="animate-ping" />
                  <circle cx="360" cy="15" r="3.5" fill="var(--color-brand-amber)" />

                  <defs>
                    <linearGradient id="graph-grad" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0%" stopColor="var(--color-brand-amber)" />
                      <stop offset="100%" stopColor="transparent" />
                    </linearGradient>
                  </defs>
                </svg>

                {/* X-Axis coordinate stamps */}
                <div className="absolute -bottom-5 left-0 right-0 flex justify-between font-mono text-[8px] text-slate-500">
                  <span>02:00</span>
                  <span>06:00</span>
                  <span>10:00</span>
                  <span>14:00</span>
                  <span>18:00</span>
                  <span>LIVE NOW</span>
                </div>
              </div>

              {/* Micro diagnostic labels */}
              <div className="flex justify-between items-center text-[9px] font-mono text-slate-400 mt-6 pt-2 border-t border-slate-800/60">
                <div className="flex items-center gap-1">
                  <span className="w-1.5 h-1.5 rounded-full bg-emerald-500" />
                  <span>Nairobi CDN Edge Node</span>
                </div>
                <span>Total clicks for this alias: <strong className="text-brand-amber">{totalClicks.toLocaleString()}</strong></span>
              </div>
            </div>

            {/* Geographical clicks & device split grids */}
            <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
              
              {/* Box 1: Kenya Location clicks breakdown */}
              <div className="bg-slate-950 border border-slate-800 p-4 rounded-2xl space-y-3">
                <span className="text-[10px] font-mono text-slate-500 block uppercase tracking-wider">Top Visitor Locations</span>
                <div className="space-y-2.5 font-mono text-xs">
                  {Object.entries(locationClicks).map(([loc, clicks]) => {
                    const total = (Object.values(locationClicks) as number[]).reduce((a, b) => a + b, 0);
                    const clicksNum = clicks as number;
                    const pct = Math.round((clicksNum / total) * 100);
                    return (
                      <div key={loc} className="space-y-1">
                        <div className="flex justify-between text-[11px]">
                          <span className="text-slate-300 font-bold">{loc}</span>
                          <span className="text-slate-400">{clicksNum.toLocaleString()} clicks ({pct}%)</span>
                        </div>
                        <div className="w-full bg-slate-800/80 h-1.5 rounded-full overflow-hidden">
                          <div 
                            className="bg-brand-amber h-full transition-all duration-1000" 
                            style={{ width: `${pct}%` }} 
                          />
                        </div>
                      </div>
                    );
                  })}
                </div>
              </div>

              {/* Box 2: Device Clicks Breakdown & Activity Logs */}
              <div className="bg-slate-950 border border-slate-800 p-4 rounded-2xl flex flex-col justify-between">
                <div>
                  <span className="text-[10px] font-mono text-slate-500 block uppercase tracking-wider mb-3">Live Clicks Activity Feed</span>
                  <div className="space-y-2">
                    {clickLogs.map((click) => (
                      <div key={click.id} className="flex items-center justify-between text-[10px] font-mono border-b border-slate-900 pb-1.5 last:border-0 last:pb-0">
                        <div className="flex items-center gap-1.5">
                          {click.device === 'Mobile' ? (
                            <Smartphone className="w-3 h-3 text-slate-400" />
                          ) : click.device === 'Desktop' ? (
                            <Laptop className="w-3 h-3 text-slate-400" />
                          ) : (
                            <Database className="w-3 h-3 text-brand-amber" />
                          )}
                          <span className="text-slate-200 font-semibold truncate max-w-[90px]">{click.location}</span>
                        </div>
                        <span className="text-[9px] text-brand-gold bg-brand-gold/10 px-1 py-0.2 rounded shrink-0">{click.isp}</span>
                        <span className="text-[9px] text-slate-500 shrink-0">{click.time}</span>
                      </div>
                    ))}
                  </div>
                </div>

                <div className="pt-3 border-t border-slate-900 mt-3 flex justify-between items-center text-[9px] font-mono text-slate-500">
                  <span className="flex items-center gap-1">
                    <Clock className="w-3 h-3" />
                    <span>Real-time polling: 3s</span>
                  </span>
                  <span>ISP Routing: Safaricom / Airtel peerings</span>
                </div>
              </div>

            </div>
          </div>

          {/* Clean high contrast Comparison Block */}
          <div className="mt-6 pt-6 border-t border-slate-800/60 grid grid-cols-1 md:grid-cols-2 gap-4">
            <div className="space-y-1">
              <span className="text-[10px] font-mono text-brand-amber font-bold uppercase tracking-wider">mcf.link Enterprise Advantage</span>
              <p className="text-[11px] text-slate-300 leading-relaxed font-light">
                Specifically built to compress bulky vehicle diagnostic telemetry, job card details, or quotation coordinates. Bitly and TinyURL charge hefty premiums, place cookies on your client devices, and show annoying ads upon redirects, hurting your garage reputation.
              </p>
            </div>

            <div className="bg-slate-950/60 p-3 rounded-xl border border-slate-800/40 space-y-1.5">
              <span className="text-[9px] font-mono text-slate-400 block uppercase tracking-wider">Why we are better:</span>
              <ul className="text-[9.5px] font-mono text-slate-300 space-y-1 font-light">
                <li className="flex items-center gap-1"><span className="text-emerald-500 font-bold">✔</span> 100% Free for Kenyan garages</li>
                <li className="flex items-center gap-1"><span className="text-emerald-500 font-bold">✔</span> Zero Ad-networks or tracking cookies</li>
                <li className="flex items-center gap-1"><span className="text-emerald-500 font-bold">✔</span> Direct integration with AA / NTSA databases</li>
                <li className="flex items-center gap-1"><span className="text-emerald-500 font-bold">✔</span> Deep SMS payload optimization</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}
